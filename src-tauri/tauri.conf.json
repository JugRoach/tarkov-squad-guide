{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Tarkov Planner",
  "version": "0.7.2",
  "identifier": "com.tarkovguide.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tarkov Planner",
        "width": 900,
        "height": 700,
        "minWidth": 500,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzM0I1MEQzMzVCNTM3MkUKUldRdU43VTEwMUE3SStocDZQQ0h2VUppcGNYeXh4RDRnOFRmTURQT20yUWVmS0tvV3BqU0Uyc1YK",
      "endpoints": [
        "https://github.com/JugRoach/tarkov-squad-guide/releases/latest/download/latest.json"
      ]
    }
  }
}
